# Dependencies are restored from package-lock.json with npm install.
node_modules/

# Intermediate TypeScript compiler output (tsc emits here; scripts/sync-ts-output.cjs
# copies the relevant files back next to their .ts sources in assets/, and
# scripts/build-static.cjs copies those into dist/). Not meant to be committed.
build/

# Ad-hoc copies of dist/ used for build-determinism testing (dist/ itself is
# tracked and committed intentionally for deployment).
dist_run*/

